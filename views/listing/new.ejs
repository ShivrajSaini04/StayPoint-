<% layout("/layouts/boilerplate") %>
    <div class="row">
        <div class="col-8 offset-2">
            <h3> Create New List</h3>
            <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">
                <div>
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" placeholder="Enter title" type="text" class="form-control" required>
                    <div class="invalid-feedback">Please enter a title.</div>
                </div>
                <br>
                <div>
                    <label for="description" class="form-label">Description</label>
                    <input name="listing[description]" placeholder="Enter description" type="text" class="form-control"
                        required>
                    <div class="invalid-feedback">Please enter a description.</div>
                </div>
                <br>
                <div>
                    <label for="image" class="form-label">Upload Listing Image</label>
                    <input name="image" type="file" class="form-control">
                </div>
                <br>
                <div class="row">
                    <div class="col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input name="listing[price]" placeholder="Enter price" type="number" class="form-control"
                            required>
                        <div class="invalid-feedback">Please enter a price.</div>
                    </div>
                    <br>
                    <div class="col-md-8">
                        <label for="location" class="form-label">Location</label>
                        <input name="listing[location]" placeholder="Enter location" type="text" class="form-control"
                            required>
                        <div class="invalid-feedback">Please enter a location.</div>
                    </div>

                </div>
                <br>
                <div>
                    <label for="country" class="form-label">Country</label>
                    <input name="listing[country]" placeholder="Enter country" type="text" class="form-control"
                        required>
                    <div class="invalid-feedback">Please enter a country.</div>
                </div><br>
                <button class="btn btn-dark add-btn"> Add</button>
                <br><br>
            </form>
        </div>
    </div>