
<% layout("/layouts/boilerplate") %>

    <div class="filters mt-3 mb-2">
        <div class="filter">
            <i class="fa-solid fa-umbrella-beach"></i>
            <p>Beaches</p>
        </div>
    
        <div class="filter">
            <i class="fa-solid fa-mountain"></i>
            <p>Mountains</p>
        </div>
    
        <div class="filter">
            <i class="fa-solid fa-place-of-worship"></i>
            <p>Spiritual</p>
        </div>
    
        <div class="filter">
            <i class="fa-solid fa-landmark"></i>
            <p>Heritage</p>
        </div>
    
        <div class="filter">
            <i class="fa-solid fa-tree"></i>
            <p>Nature</p>
        </div>
    
        <div class="filter">
            <i class="fa-solid fa-city"></i>
            <p>Cities</p>
        </div>
    
        <div class="filter">
            <i class="fa-solid fa-paw"></i>
            <p>Wildlife</p>
        </div>
    
        <div class="filter">
            <i class="fa-solid fa-sun"></i>
            <p>Desert</p>
        </div>
    
        <div class="filter">
            <i class="fa-solid fa-person-hiking"></i>
            <p>Adventure</p>
        </div>
    </div>
    
    <!-- <form method="GET" action="/listings/new">
        <button>ADD New List</button>
    </form> -->
    <div class="row row-cols-lg-3 gx-4 row-cols-md-2 row-cols-sm-1 listing-container">
        <% for( listing of allListing){ %>
            <a href="/listings/<%=listing._id%>" class="card-link" >
            <div class="card col listing-card" style="width: 20rem;">
                <img src="<%=listing.image.url%>" class="card-img-top " alt="listing_image" style="height:20rem">
                <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text">
                       <b> <%= listing.title %> </b> 
                            <br />
                            &#8377; <%= listing.price.toLocaleString("en-IN") %> / Night
                    </p>
                </div>
            </div>
            </a>

            <% } %>
    </div>


